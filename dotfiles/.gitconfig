[push]
	autoSetupRemote = true
[pull]
	rebase = true
[commit]
	gpgsign = true


[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
[merge]
    conflictStyle = zdiff3